# FedComp Index - copy to .env and fill in values. Never commit .env.

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
D1_DATABASE_ID=

# Resend (email alerts)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@fedcompindex.com

# SAM.gov
SAM_GOV_API_KEY=

# Site
SITE_URL=http://localhost:5500
DATA_DATE=2026-01-01

# Data backup repo
DATA_REPO_URL=https://github.com/hydrablitz/FedComp-Data.git
